{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PROJECT_DIR}/../VirtualOffice/scripts/run-office-hook.ps1",
              "-Provider",
              "claude",
              "-Agent",
              "mj-app-dev"
            ],
            "timeout": 10
          }
        ]
      }
